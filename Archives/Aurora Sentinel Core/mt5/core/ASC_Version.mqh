#define ASC_TRUTH_SEEKER_SOURCE_IDENTITY_TOKEN "RUN141R|dossier_first_hud_off|hud_runtime_disabled_by_default_scanner_truth_outputs_preserved|compile_claim_not_made_live_claim_not_made"
#define ASC_TRUTH_SEEKER_ARTIFACT_SCHEMA_VERSION "ASC_ARTIFACT_SCHEMA_V1"

string ASC_SourceRunId()
  {
   return ASC_TRUTH_SEEKER_CURRENT_RUN;
  }

string ASC_SourceVersionLabel()
  {
   return ASC_VERSION_LABEL;
  }

string ASC_SourceIdentityToken()
  {
   return ASC_TRUTH_SEEKER_SOURCE_IDENTITY_TOKEN;
  }

string ASC_ArtifactSchemaVersion()
  {
   return ASC_TRUTH_SEEKER_ARTIFACT_SCHEMA_VERSION;
  }

string ASC_BuildSourceArtifactIdentityToken()
  {
   string token = "source_run_id=" + ASC_SourceRunId();
   token += " | source_version=" + ASC_SourceVersionLabel();
   token += " | source_identity_token=" + ASC_SourceIdentityToken();
   token += " | artifact_written_by_run=" + ASC_SourceRunId();
   token += " | artifact_schema_version=" + ASC_ArtifactSchemaVersion();
   token += " | build_identity_present=true";
   token += " | fake_hash=false";
   token += " | compile_hash=not_claimed";
   token += " | proof_boundary=" + ASC_TRUTH_SEEKER_RUN101R_PROOF_BOUNDARY;
   token += " | next_live_checkpoint=";
   token += ASC_TRUTH_SEEKER_NEXT_LIVE_PROOF_RUN;
   return token;
  }

string ASC_ArtifactFreshnessStatusFromState(const string artifact_state)
  {
   string normalized = artifact_state;
   StringToLower(normalized);

   if(StringLen(normalized) <= 0 || normalized == "missing")
      return "missing";
   if(StringFind(normalized, "archive") >= 0 || StringFind(normalized, "historical") >= 0)
      return "archive_historical_only";
   if(StringFind(normalized, "staging") >= 0 || StringFind(normalized, "pending") >= 0 || StringFind(normalized, "queued") >= 0 || StringFind(normalized, "inflight") >= 0)
      return "staging_not_current";
   if(StringFind(normalized, "retained") >= 0 || StringFind(normalized, "last_good") >= 0 || StringFind(normalized, "last-good") >= 0)
      return "retained_last_good_not_current";
   if(StringFind(normalized, "continuity") >= 0 || StringFind(normalized, "fallback") >= 0)
      return "continuity_fallback";
   if(StringFind(normalized, "stale") >= 0 || StringFind(normalized, "mismatch") >= 0)
      return "stale_not_current";
   if(StringFind(normalized, "degraded") >= 0)
      return "degraded_current";
   if(StringFind(normalized, "promoted") >= 0)
      return "promoted_current";
   if(StringFind(normalized, "written_by_current_run") >= 0 || StringFind(normalized, "written_by_run") >= 0)
      return "written_by_current_run";
   if(StringFind(normalized, "file_exists") >= 0)
      return "file_exists_only";
   if(StringFind(normalized, "non_empty") >= 0)
      return "non_empty_unproven";
   if(StringFind(normalized, "selected_symbol_none") >= 0)
      return "selected_symbol_none_not_failure";
   if(normalized == "current" || StringFind(normalized, "clean_current") >= 0 || StringFind(normalized, "aligned_current") >= 0)
      return "promoted_current";
   return "current_runtime_unproven";
  }

string ASC_ArtifactFreshnessBoundaryLine(const string artifact_family_id, const string artifact_state)
  {
   string status = ASC_ArtifactFreshnessStatusFromState(artifact_state);
   string line = "Artifact Freshness: artifact_family_id=" + (StringLen(artifact_family_id) > 0 ? artifact_family_id : "unclassified");
   line += " | artifact_freshness_status=" + status;
   line += " | freshness_taxonomy=file_exists_only,non_empty_unproven,written_by_current_run,promoted_current,current_runtime_unproven,staging_not_current,archive_historical_only,retained_last_good_not_current,stale_not_current,degraded_current,continuity_fallback,missing,selected_symbol_none_not_failure";
   line += " | current_requires_written_by_run_and_promoted=true";
   line += " | file_exists_is_fresh_current_promoted_proof=false";
   line += " | retained_is_current=false | stale_is_current=false | staging_is_current=false | archive_is_current=false";
   line += " | staging_not_current=true | archive_historical_only=true | retained_last_good_not_current=true | stale_not_current=true";
   line += " | current_focus_truth_owner=false | selected_symbol_dossier_mirror=true";
   return line;
  }

string ASC_ArtifactIdentityLine(const string artifact_family_id, const string artifact_state)
  {
   string line = "Artifact Identity: artifact_family_id=" + (StringLen(artifact_family_id) > 0 ? artifact_family_id : "unclassified");
   line += " | artifact_state=" + (StringLen(artifact_state) > 0 ? artifact_state : "unknown");
   line += " | " + ASC_BuildSourceArtifactIdentityToken();
   line += "\n" + ASC_ArtifactFreshnessBoundaryLine(artifact_family_id, artifact_state);
   return line;
  }

